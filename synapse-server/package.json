{
  "name": "@mcp-apps/synapse-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Azure Synapse workspace operations including ADLS Gen2 and pipeline management",
  "main": "dist/index.js",
  "type": "commonjs",
  "bin": {
    "synapse-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "node --no-warnings --enable-source-maps dist/index.js",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run",
    "debug": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/identity-broker": "^1.4.0",
    "@azure/storage-blob": "^12.31.0",
    "@azure/storage-file-datalake": "^12.29.0",
    "@azure/synapse-artifacts": "^1.0.0-beta.16",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "vscode-mcp-server": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}